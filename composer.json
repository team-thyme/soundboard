{
    "type": "project",
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.2.0"
        }
    },
    "scripts": {
        "dev-server": [
            "Composer\\Config::disableProcessTimeout",
            "php -S 0.0.0.0:32658 public-api/index.php"
        ]
    },
    "autoload": {
        "psr-4": {
            "TeamThyme\\Soundboard\\": "backend/src"
        }
    },
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "php-di/php-di": "^7.1.1",
        "php-di/slim-bridge": "^3.4.1",
        "slim/psr7": "^1.8",
        "slim/slim": "^4.15.2",
        "symfony/dotenv": "^7.4.14"
    },
    "require-dev": {
        "symfony/var-dumper": "^7.4.14"
    }
}
